# Copy to .env.local for local dev. Vite injects only VITE_*-prefixed
# vars into the client bundle, so anything not prefixed stays server-side.

# --- Backend proxy ---------------------------------------------------------
# Where the Vite dev proxy forwards /v1/* requests during development.
# Point this at a locally-running `bin/api`.
VITE_API_PROXY=http://localhost:8080

# --- OIDC mode (production-like) ------------------------------------------
# OIDC issuer URL — must match the `iss` claim Keycloak puts in tokens.
# For Skycloak: https://<tenant>.app.skycloak.io/realms/<realm>
VITE_OIDC_ISSUER=https://d5b0c22a-cf99-45fd-9391-4440ef20ffee.app.skycloak.io/realms/master

# Public OIDC client ID — also used as the audience the API checks.
VITE_OIDC_CLIENT_ID=deploy-bot-ui

# --- Dev-auth mode (skips OIDC) -------------------------------------------
# Set VITE_DEV_AUTH=true to render a username/password form instead of
# the OIDC redirect. The API must be started with
# api.enable_admin_account=true and matching api.admin_credentials.
# When VITE_DEV_AUTH=true, VITE_OIDC_ISSUER is ignored.
# VITE_DEV_AUTH=true

# --- Dev mocks (no backend at all) ----------------------------------------
# When VITE_DEV_MOCKS=true, MSW intercepts /v1/* in the browser and
# serves canned data. Useful for UI iteration without a running api binary.
# VITE_DEV_MOCKS=true
